generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum EscrowState {
  CREATED
  FUNDED
  SHIPPED
  DELIVERED
  COMPLETED
  DISPUTED
  REFUNDED
}

enum DisputeStatus {
  OPEN
  IN_REVIEW
  RESOLVED
}

model Escrow {
  id            String         @id @default(uuid())
  itemName      String
  itemRef       String
  amount        Decimal        @db.Decimal(18, 8)
  currency      String
  buyerAddress  String
  vendorAddress String
  state         EscrowState    @default(CREATED)
  trackingId    String?
  shippedAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  disputes      Dispute[]
  notifications Notification[]

  @@index([vendorAddress])
  @@index([buyerAddress])
}

model Dispute {
  id        String        @id @default(uuid())
  escrowId  String
  status    DisputeStatus @default(OPEN)
  reason    String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  escrow    Escrow        @relation(fields: [escrowId], references: [id], onDelete: Cascade)

  @@index([status])
}

model Notification {
  id               String   @id @default(uuid())
  escrowId         String
  type             String
  channel          String
  recipientAddress String
  message          String
  createdAt        DateTime @default(now())
  escrow           Escrow   @relation(fields: [escrowId], references: [id], onDelete: Cascade)
}
